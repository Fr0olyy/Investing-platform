PROJECT_NAME=Investment Platform API
PROJECT_DESCRIPTION=Educational trading simulator backend
VERSION=1.0.0
API_V1_PREFIX=/api/v1

SECRET_KEY=change-me-before-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

STARTING_BALANCE=1000000
BASE_CURRENCY=RUB

DEBUG=false
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

ENABLE_BACKGROUND_JOBS=true
QUOTE_REFRESH_MINUTES=30
ML_REFRESH_HOURS=12
MARKET_DATA_PROVIDER=real
ML_ARTIFACTS_DIR=./ml/artifacts
ML_DATASETS_DIR=./ml/datasets
ML_EXPERIMENTS_DIR=./ml/experiments
ML_MODEL_TYPE=linear_regression
ML_LOOKBACK_YEARS=3
ML_TEST_RATIO=0.2
ML_MIN_DATA_POINTS=120
ML_HORIZON_DAYS=1
ML_AUTO_TRAIN_ON_STARTUP=true

MOEX_BASE_URL=https://iss.moex.com/iss
CBR_BASE_URL=https://www.cbr.ru
FRED_BRENT_CSV_URL=https://fred.stlouisfed.org/graph/fredgraph.csv?id=DCOILBRENTEU

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=investing_platform
DATABASE_URL=sqlite:///./investing_platform.db
